{
	"version": "2.0.0",
	"tasks": [
		{
			"label": "copilot-check-target-remote",
			"type": "shell",
			"command": "git",
			"args": [
				"ls-remote",
				"https://github.com/colourpixdev/psgrebrand.git",
				"HEAD"
			],
			"isBackground": false,
			"group": "build"
		},
		{
			"label": "copilot-deploy-commit",
			"type": "shell",
			"command": "git",
			"args": [
				"commit",
				"-am",
				"Build production assets"
			],
			"isBackground": false,
			"group": "build"
		},
		{
			"label": "copilot-last-author",
			"type": "shell",
			"command": "git",
			"args": [
				"log",
				"-1",
				"--pretty=format:%an|%ae"
			],
			"isBackground": false,
			"group": "build"
		},
		{
			"label": "copilot-last-author-quoted",
			"type": "shell",
			"command": "git",
			"args": [
				"log",
				"-1",
				"--pretty=format:\"%an|%ae\""
			],
			"isBackground": false,
			"group": "build"
		},
		{
			"label": "copilot-last-author-name",
			"type": "shell",
			"command": "git",
			"args": [
				"log",
				"-1",
				"--pretty=format:%an"
			],
			"isBackground": false,
			"group": "build"
		},
		{
			"label": "copilot-last-author-email",
			"type": "shell",
			"command": "git",
			"args": [
				"log",
				"-1",
				"--pretty=format:%ae"
			],
			"isBackground": false,
			"group": "build"
		},
		{
			"label": "copilot-configure-commit-identity",
			"type": "shell",
			"command": "powershell",
			"args": [
				"-NoProfile",
				"-Command",
				"git config user.name \"francois2botha-star\"; git config user.email \"francois2botha@gmail.com\"; git commit -am \"Build production assets\""
			],
			"isBackground": false,
			"group": "build"
		},
		{
			"label": "copilot-set-git-name",
			"type": "shell",
			"command": "git",
			"args": [
				"config",
				"user.name",
				"francois2botha-star"
			],
			"isBackground": false,
			"group": "build"
		},
		{
			"label": "copilot-set-git-email",
			"type": "shell",
			"command": "git",
			"args": [
				"config",
				"user.email",
				"francois2botha@gmail.com"
			],
			"isBackground": false,
			"group": "build"
		},
		{
			"label": "copilot-deploy-commit-retry",
			"type": "shell",
			"command": "git",
			"args": [
				"commit",
				"-am",
				"Build production assets"
			],
			"isBackground": false,
			"group": "build"
		},
		{
			"label": "copilot-stage-new-build-files",
			"type": "shell",
			"command": "git",
			"args": [
				"add",
				"-A"
			],
			"isBackground": false,
			"group": "build"
		}
	]
}